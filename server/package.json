    "start": "node dist/index.js"
  },
  "dependencies": {
    "@game/shared": "*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  }
}
