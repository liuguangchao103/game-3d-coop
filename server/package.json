{
  "name": "@game/server",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/index.ts",
    "build": "tsc -p tsconfig.json",
